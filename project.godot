; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="G.U.I.D.E-CSharp"
config/features=PackedStringArray("4.2", "C#", "GL Compatibility")
config/icon="res://assets/guideCS.png"

[autoload]

GUIDE="*res://addons/guideCS/guide/guide.gd"
GuideCs="*res://addons/guideCS/Guide.cs"

[dotnet]

project/assembly_name="G.U.I.D.E-CSharp"

[editor_plugins]

enabled=PackedStringArray("res://addons/guideCS/guide/plugin.cfg", "res://addons/guideCS/plugin.cfg")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
